# ------------------------------------------------------------------
# Chinook Overlander — environment variables
# Copy to `.env.local` and fill in. Everything is OPTIONAL: with no
# variables set, the site runs on typed seed content + curated feeds.
# ------------------------------------------------------------------

# --- Site ---
# Public canonical URL (used for metadata, sitemap, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://chinookoverlander.com

# --- YouTube (live) ---
# The channel is wired in out of the box via YouTube's public RSS feed
# (no API key required) using the channel id baked into lib/site.ts:
#   Channel: https://www.youtube.com/@ChinookOverlander  (UCN1_yGJq165XCwl7UmYbhqQ)
#
# Optional: set YOUTUBE_API_KEY to switch to the Data API v3 for richer
# thumbnails and more results. YOUTUBE_CHANNEL_ID overrides the default id.
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# --- Sanity CMS (embedded Studio at /studio) ---
# When NEXT_PUBLIC_SANITY_PROJECT_ID is set, content is read from Sanity
# and the Studio activates. Otherwise the site uses seed content.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# --- Newsletter (provider-agnostic) ---
# EMAIL_PROVIDER: dev (logs only) | convertkit | ...
EMAIL_PROVIDER=dev
CONVERTKIT_API_KEY=
CONVERTKIT_FORM_ID=

# --- Instagram (live via official Graph API) ---
# Requires a Creator/Business account. Set a long-lived access token and the
# homepage pulls your latest posts live (cached 1 hour) into the site's own
# gallery. To get the token:
#   1. developers.facebook.com → Create App → type "Business".
#   2. Add product "Instagram" → "API setup with Instagram login".
#   3. Add your IG account, then "Generate token" (authorise @chinookoverlander).
#   4. Exchange for a 60-day token:
#        curl -s "https://graph.instagram.com/access_token?grant_type=ig_exchange_token&client_secret=APP_SECRET&access_token=SHORT_TOKEN"
#   5. Paste the long-lived token below. Refresh before it expires with:
#        curl -s "https://graph.instagram.com/refresh_access_token?grant_type=ig_refresh_token&access_token=CURRENT_TOKEN"
INSTAGRAM_ACCESS_TOKEN=

# Fallbacks (optional): a third-party widget id, else curated content /
# instagramEmbeds in lib/content/instagram.ts are used when no token is set.
NEXT_PUBLIC_INSTAGRAM_WIDGET_ID=
